---
import BaseLayout from '../layouts/BaseLayout.astro';
---


<BaseLayout title="Luiz Contes">
		<main class="home-shell">
			<section id="hero" class="home-section hero-section">
				<p class="hero-eyebrow" data-i18n="hero.eyebrow">Software Engineer and Builder</p>
				<h1 data-i18n="hero.title">Luiz Contes</h1>
				<p class="hero-support" data-i18n="hero.support">
					I build practical software, share what I learn, and focus on long-term thinking across tech and life.
				</p>
				<div class="hero-actions">
					<a class="hero-cta hero-cta-primary" href="#contact" data-i18n="hero.cta.contact">Contact</a>
					<a class="hero-cta hero-cta-secondary" href="/projects" data-i18n="hero.cta.projects">View Projects</a>
				</div>
			</section>
			<section id="who-i-am" class="home-section">
				<h2 data-i18n="section.whoIAm">Who I Am</h2>
			</section>
			<section id="projects" class="home-section">
				<h2 data-i18n="section.projects">Projects</h2>
			</section>
			<section id="blog" class="home-section">
				<h2 data-i18n="section.recentPosts">Recent Posts</h2>
			</section>
		</main>
		<script>
			import { initHomePage } from '../scripts/home-page';
			initHomePage();
		</script>
</BaseLayout>
