---
import BaseLayout from "../layouts/BaseLayout.astro";
import SendEmailButton from "../components/send-email-button/SendEmailButton.astro";
import ContentSection from "../components/content-section/ContentSection.astro";
---

<BaseLayout title="Luiz Contes">
	<main class="home-shell">
		<section id="hero" class="home-section hero-section">
			<div class="hero-layout">
				<div class="hero-copy">
					<div class="hero-top">
						<h1 class="hero-title" data-i18n="hero.title">Luiz Contes</h1>
						<p class="hero-eyebrow" data-i18n="hero.eyebrow">
							Software Engineer and Builder
						</p>
					</div>
					<div class="hero-body">
						<p class="hero-support" data-i18n="hero.support">
							I build practical software, share what I learn, and focus on
							long-term thinking across tech and life — driven by a genuine
							commitment to engineering that creates real, lasting value. With a
							track record across diverse domains, I thrive at the intersection of
							technical depth and clear communication, turning complex problems into
							solutions that are elegant, maintainable, and built to last.
						</p>
					</div>
					<div class="hero-actions">
						<a
							href="/who-i-am"
							class="hero-cta hero-cta-secondary"
							data-i18n="hero.cta.whoIAm">Who I Am</a
						>
						<SendEmailButton
							className="send-email-button send-email-button--align-left hero-cta hero-cta-primary"
						/>
					</div>
				</div>
				<div class="hero-media">
					<img
						class="hero-image"
						src="/images/me.png"
						alt="Portrait of Luiz Contes"
						loading="lazy"
						decoding="async"
					/>
				</div>
			</div>
		</section>
		<section id="projects" class="home-section">
			<ContentSection titleKey="section.projects" titleDefault="Projects" />
		</section>
		<section id="blog" class="home-section">
			<ContentSection
				titleKey="section.recentPosts"
				titleDefault="Recent Posts"
			/>
		</section>
	</main>

