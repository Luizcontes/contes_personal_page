---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog — Luiz Contes">
	<main class="home-shell">
		<section class="home-section">
			<h1 class="blog-heading">Blog</h1>
			<ul class="blog-list">
				{posts.map((post) => (
					<li class="blog-card">
						<a href={`/blog/${post.id}`} class="blog-card-link">
							{post.data.cover && (
								<img
									class="blog-card-cover"
									src={post.data.cover}
									alt=""
									width="800"
									height="420"
									loading="lazy"
									decoding="async"
								/>
							)}
							<div class="blog-card-body">
								<div class="blog-card-meta">
									<time datetime={post.data.date.toISOString()}>
										{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
									</time>
									<span class="blog-card-tags">
										{post.data.tags.map((tag) => (
											<span class="blog-tag">{tag}</span>
										))}
									</span>
								</div>
								<h2 class="blog-card-title">{post.data.title}</h2>
								<p class="blog-card-desc">{post.data.description}</p>
							</div>
						</a>
					</li>
				))}
			</ul>
		</section>
	</main>
</BaseLayout>

<style>
	.blog-heading {
		margin: 0 0 var(--space-8);
	}

	.blog-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: var(--space-8);
	}

	.blog-card {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		overflow: hidden;
		background-color: var(--color-surface);
		transition: box-shadow var(--duration-base) var(--ease-standard);
	}

	.blog-card:hover {
		box-shadow: var(--shadow-md);
	}

	.blog-card-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.blog-card-cover {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		display: block;
	}

	.blog-card-body {
		padding: var(--space-6);
		display: grid;
		gap: var(--space-3);
	}

	.blog-card-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-3);
		font-size: 0.875rem;
		color: var(--color-text-muted);
	}

	.blog-card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.blog-tag {
		background-color: var(--color-border);
		color: var(--color-text-muted);
		border-radius: var(--radius-sm);
		padding: 0.125rem var(--space-2);
		font-size: 0.75rem;
	}

	.blog-card-title {
		margin: 0;
		font-size: clamp(1.125rem, 2.2vw, 1.375rem);
		color: var(--color-text);
		line-height: 1.3;
	}

	.blog-card:hover .blog-card-title {
		color: var(--color-accent-cyan);
	}

	.blog-card-desc {
		margin: 0;
		color: var(--color-text-muted);
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	@media (min-width: 768px) {
		.blog-list {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
