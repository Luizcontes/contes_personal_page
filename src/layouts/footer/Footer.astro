---
import './footer.css';
import { defaultLang } from '../../i18n/ui';
import SendEmailButton from '../../components/send-email-button/SendEmailButton.astro';

interface Props {
	locale?: string;
}

const { locale = defaultLang } = Astro.props;
---

<footer class="site-footer">
	<div class="footer-content">
		<p class="footer-text" data-i18n="footer.tagline">Let's turn your idea into reality.</p>
		<SendEmailButton locale={locale} />
	</div>
</footer>