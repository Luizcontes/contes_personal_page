---
import { CONTACT_EMAIL } from '../constants/app';
import { defaultLang } from '../i18n/ui';
import { getContactMailtoHref } from '../i18n/utils';

interface Props {
	locale?: string;
	ctaClassName?: string;
}

const { locale = defaultLang, ctaClassName = 'hero-cta hero-cta-primary' } = Astro.props;
const contactFallbackMailtoHref = `mailto:${CONTACT_EMAIL}`;
const contactMailtoHref = getContactMailtoHref(locale);
---

<section id="contact" class="home-section">
	<h2 data-i18n="section.contact">Contact</h2>
	<a
		class={ctaClassName}
		href={contactMailtoHref}
		data-contact-email-link
		data-contact-fallback-mailto={contactFallbackMailtoHref}
		data-i18n="contact.cta.email"
	>
		Send Email
	</a>
</section>
